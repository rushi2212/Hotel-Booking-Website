# OpenRouter is used for screenshot-based AI vision verification.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=Hotel Booking Test Automation
OPENROUTER_RETRIES=3
OPENROUTER_TIMEOUT_SECONDS=60

# Set true when the report must fail instead of using local fallback if AI vision is unavailable.
AI_VERIFICATION_REQUIRED=false
